generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum BookingStatus {
  PENDING
  ACCEPTED
  REJECTED
  COMPLETED
}

enum UserRole {
  OWNER
  ADMIN
  DOCTOR
  RECEPTIONIST
}

enum Gender {
  MALE
  FEMALE
  OTHER
  UNKNOWN
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

model Clinic {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]
  services  Service[]
  doctors   Doctor[]
  patients  Patient[]
  bookings  Booking[]
  reviews   Review[]
  auditLogs AuditLog[]
  notifications Notification[]
}

model User {
  id           String   @id @default(cuid())
  clinicId     String
  username     String   @unique
  passwordHash String
  role         UserRole @default(OWNER)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  clinic    Clinic     @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  sessions  Session[]
  auditLogs AuditLog[]
  notifications Notification[]

  @@index([clinicId])
}

model Session {
  id               String    @id @default(cuid())
  userId           String
  jti              String    @unique
  refreshTokenHash String?
  ipHash           String?
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  clinicId  String?
  userId    String?
  action    String
  entity    String
  entityId  String?
  ip        String?
  metadata  Json?
  oldData   Json?
  newData   Json?
  createdAt DateTime @default(now())

  clinic Clinic? @relation(fields: [clinicId], references: [id], onDelete: SetNull)
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([clinicId, createdAt])
  @@index([action, createdAt])
  @@index([entity, entityId])
}

model TelegramActionToken {
  id        String    @id @default(cuid())
  token     String    @unique
  bookingId String
  action    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([expiresAt])
}

model TelegramPendingReject {
  id        String   @id @default(cuid())
  chatId    String
  userId    String
  bookingId String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@unique([chatId, userId])
  @@index([expiresAt])
}

model Service {
  id             String   @id @default(cuid())
  clinicId       String
  nameRu         String
  nameTj         String
  descriptionRu  String
  descriptionTj  String
  durationMin    Int      @default(30)
  price          Int?
  iconName       String?
  indicationsRu  String?
  indicationsTj  String?
  advantagesRu   String?
  advantagesTj   String?
  preparationRu  String?
  preparationTj  String?
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  clinic   Clinic          @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  doctors  DoctorService[]
  bookings Booking[]

  @@index([clinicId, active])
}

model Doctor {
  id          String   @id @default(cuid())
  clinicId    String
  nameRu      String
  nameTj      String
  specialtyRu String
  specialtyTj String
  photoUrl    String?
  workDays    Int[]
  workStart   String
  workEnd     String
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  clinic   Clinic          @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  services DoctorService[]
  bookings Booking[]
  reviews  Review[]

  @@index([clinicId, active])
}

model DoctorService {
  doctorId  String
  serviceId String

  doctor  Doctor  @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([doctorId, serviceId])
}

model Patient {
  id        String    @id @default(cuid())
  clinicId  String
  firstName String
  lastName  String
  phone     String
  phoneHash String
  email     String?
  birthDate DateTime?
  gender    Gender?
  address   String?
  notes     String?
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  clinic   Clinic    @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  bookings Booking[]
  reviews  Review[]

  @@unique([clinicId, phoneHash])
  @@index([clinicId, createdAt])
  @@index([clinicId, lastName, firstName])
  @@index([clinicId, phone])
  @@index([clinicId, email])
  @@index([clinicId, deletedAt])
}

model Booking {
  id              String        @id @default(cuid())
  clinicId        String
  patientId       String?
  serviceId       String
  doctorId        String
  firstName       String
  lastName        String
  phone           String
  phoneHash       String
  date            String
  timeSlot        String
  status          BookingStatus @default(PENDING)
  rejectionReason String?
  tgMessageId     Int?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  clinic  Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient Patient? @relation(fields: [patientId], references: [id], onDelete: SetNull)
  service Service  @relation(fields: [serviceId], references: [id])
  doctor  Doctor   @relation(fields: [doctorId], references: [id])
  review  Review?

  @@index([clinicId, status])
  @@index([clinicId, date])
  @@index([doctorId, date, timeSlot])
  @@index([phoneHash, createdAt])
  @@index([patientId])
  @@index([clinicId, patientId])
}

model Review {
  id        String       @id @default(cuid())
  clinicId  String
  patientId String
  doctorId  String
  bookingId String       @unique
  rating    Int
  comment   String?
  status    ReviewStatus @default(PENDING)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  clinic  Clinic  @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor  Doctor  @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([clinicId])
  @@index([clinicId, status])
  @@index([clinicId, doctorId])
  @@index([clinicId, patientId])
  @@index([clinicId, createdAt])
  @@index([doctorId, status])
}

model Notification {
  id        String   @id @default(cuid())
  clinicId  String
  userId    String?
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([clinicId, read, createdAt])
  @@index([clinicId, createdAt])
  @@index([userId, read])
}

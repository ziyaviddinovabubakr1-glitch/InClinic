# Database (PostgreSQL)
# Локально: embedded Postgres / Docker. На Render: URL из панели базы (часто с ?sslmode=require)
DATABASE_URL="postgresql://user:password@localhost:5432/clinic?schema=public"
DIRECT_URL="postgresql://user:password@localhost:5432/clinic?schema=public"

# Auth — REQUIRED in production (no defaults)
JWT_SECRET="generate-a-random-string-at-least-32-characters-long"
JWT_ACCESS_TTL_SEC=1800
JWT_REFRESH_TTL_SEC=604800

# Initial owner — synced on every deploy (npm run build:deploy / seed)
ADMIN_USERNAME="InClinic"
ADMIN_PASSWORD="OwnerSecure2026!"

# Default clinic slug for single-tenant deployment
DEFAULT_CLINIC_SLUG="default"

# Telegram
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
TELEGRAM_WEBHOOK_SECRET=""
# Public HTTPS base for webhook (required for inline buttons). Example: https://xxxx.ngrok-free.app
TELEGRAM_WEBHOOK_PUBLIC_URL=""

# Redis rate limiting (Upstash — REQUIRED for production multi-instance)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Public (safe to expose in browser)
NEXT_PUBLIC_CLINIC_PHONE="+992 00 000 00 00"
NEXT_PUBLIC_CLINIC_NAME="InClinic"
# Public (safe to expose in browser). Локально — localhost; на Render не обязательно (есть RENDER_EXTERNAL_URL)
# NEXT_PUBLIC_BASE_URL="http://localhost:3001"

# Privacy — site not listed in Google; share link only (see SITE_ACCESS_KEY)
# SITE_BLOCK_INDEXING=true
# SITE_ACCESS_KEY="your-secret-link-key-min-8-chars"

# Development only
# ALLOW_MOCK_FALLBACK=true
# SKIP_TELEGRAM_IP_CHECK=true
